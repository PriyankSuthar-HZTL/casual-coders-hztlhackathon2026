# Optional — MigrateX reads Contentstack credentials from the in-app Config step
# and persists them to localStorage via Zustand. These env vars are only used if
# you want to seed defaults for local development.

NEXT_PUBLIC_DEFAULT_REGION=na
NEXT_PUBLIC_DEFAULT_ENVIRONMENT=development

# Optional — LLM keys for /api/scrape when the wizard does not send a client key.
# GEMINI_API_KEY and ANTHROPIC_API_KEY are read the same way for their providers.
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
